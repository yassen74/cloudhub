services:
  db:
    image: mariadb:11
    container_name: itverse-db
    environment:
      MARIADB_ROOT_PASSWORD: root
      MARIADB_DATABASE: lms_db
      MARIADB_USER: itverse
      MARIADB_PASSWORD: itverse123
    ports:
      - "3307:3306"
    volumes:
      - dbdata:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mariadb-admin ping -h 127.0.0.1 -uroot -proot >/dev/null 2>&1 || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 30

  web:
    build:
      context: .
      dockerfile: docker/php/Dockerfile
    container_name: itverse-web
    ports:
      - "8090:80"
    volumes:
      - ./ELearning:/var/www/html
    environment:
      DB_HOST: db
      DB_NAME: lms_db
      DB_USER: itverse
      DB_PASS: itverse123
    depends_on:
      db:
        condition: service_healthy

  phpmyadmin:
    image: phpmyadmin:latest
    container_name: itverse-phpmyadmin
    environment:
      PMA_HOST: db
      PMA_PORT: 3306
      PMA_USER: itverse
      PMA_PASSWORD: itverse123
    ports:
      - "8091:80"
    depends_on:
      db:
        condition: service_healthy

volumes:
  dbdata:
