<?php
if (session_status() !== PHP_SESSION_ACTIVE) { session_start(); }

require_once __DIR__ . '/../dbConnection.php';
include(__DIR__ . '/../mainInclude/header.php');

if (empty($_SESSION['is_login']) || empty($_SESSION['stu_id']) || empty($_SESSION['stuLogEmail'])) {
  header("Location: /loginorsignup.php");
  exit;
}

$stuId = (int)$_SESSION['stu_id'];
$stuEmail = (string)$_SESSION['stuLogEmail'];

$stmt = $conn->prepare("SELECT c.course_id, c.course_name, c.course_desc, c.course_img, o.order_date
FROM courseorder o
JOIN course c ON c.course_id = o.course_id
WHERE stu_id = ? LIMIT 1");
$stmt->bind_param("i", $stuId);
$stmt->execute();
$res = $stmt->get_result();
$profile = $res ? $res->fetch_assoc() : null;
$stmt->close();

if (!$profile) {
  echo '<div style="margin:120px auto; max-width:900px; padding:16px; font-family:Arial;"><div style="padding:12px; border:1px solid #f5c2c7; background:#f8d7da;">Profile not found.</div></div>';
  include(__DIR__ . '/../mainInclude/footer_clean.php');
  exit;
}

$stuName = (string)$profile['stu_name'];
$imgPath = (string)$profile['stu_img'];
$preferredTrack = (string)($profile['preferred_track'] ?? '');
$experienceLevel = (string)($profile['experience_level'] ?? '');

$ok = isset($_GET['ok']) ? (string)$_GET['ok'] : '';
$err = isset($_GET['err']) ? (string)$_GET['err'] : '';

$courses = [];
$q = "
  SELECT c.course_id, c.course_name, c.course_desc, c.course_img, o.order_date
  FROM courseorder o JOIN course c ON c.course_id = o.course_id co
  JOIN course c ON c.course_id = co.course_id
  WHERE co.stu_email = ?
  ORDER BY co.co_id DESC
  LIMIT 50
";
$cs = $conn->prepare($q);
$cs->bind_param("s", $stuEmail);
$cs->execute();
$r = $cs->get_result();
if ($r) {
  while ($row = $r->fetch_assoc()) $courses[] = $row;
}
$cs->close();
?>
