<script>
function mpShow(e){
  e.preventDefault();
  var a = e.currentTarget;
  var target = a.getAttribute('data-target');

  document.querySelectorAll('.mp-nav a').forEach(function(x){ x.classList.remove('active'); });
  a.classList.add('active');

  document.querySelectorAll('.mp-section').forEach(function(sec){ sec.classList.remove('show'); });
  var el = document.getElementById(target);
  if (el) el.classList.add('show');

  return false;
}
</script>

