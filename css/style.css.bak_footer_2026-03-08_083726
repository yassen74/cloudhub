/* ===== SAFE UI POLISH: HOME + COURSES (SCOPED, NON-BREAKING) ===== */
:root{
  --fayen-navy:#0b1736;
  --fayen-blue:#1d4ed8;
  --fayen-blue-2:#2563eb;
  --fayen-ink:#0f172a;
  --fayen-muted:#64748b;
  --fayen-surface:#ffffff;
  --fayen-line:#e2e8f0;
}

/* Shared navbar polish, keeps existing Bootstrap behavior */
.navbar.navbar-dark{
  background:linear-gradient(90deg,var(--fayen-navy),#12306b) !important;
  border-bottom:1px solid rgba(255,255,255,0.12);
  box-shadow:0 8px 24px rgba(2,6,23,0.22);
}
.navbar .navbar-brand{
  font-size:1.35rem;
  letter-spacing:0.4px;
}
.navbar .navbar-text{
  color:rgba(255,255,255,0.82);
  font-size:0.92rem;
}
.custom-nav .custom-nav-item .nav-link{
  border-radius:8px;
  padding:0.45rem 0.8rem !important;
  transition:background-color .2s ease,color .2s ease;
}
.custom-nav .custom-nav-item .nav-link:hover,
.custom-nav .custom-nav-item .nav-link:focus{
  background-color:rgba(255,255,255,0.11);
  color:#ffffff !important;
}

/* Homepage hero */
.home-hero{
  margin-top:64px;
}
.home-hero .vid-parent{
  min-height:calc(100vh - 64px);
}
.home-hero video{
  min-height:calc(100vh - 64px);
  object-fit:cover;
}
.home-hero .vid-overlay{
  background:linear-gradient(120deg,rgba(11,23,54,.78),rgba(16,70,178,.62));
  opacity:1;
}
.home-hero .hero-content{
  max-width:780px;
  margin:0 auto;
  padding:0 1rem;
}
.home-hero .hero-content h1{
  font-size:clamp(2.05rem,5.4vw,4rem);
  line-height:1.1;
  margin-bottom:.75rem;
}
.home-hero .hero-content h1 span{
  color:#93c5fd;
}
.home-hero .hero-content p{
  color:rgba(255,255,255,.9);
  font-size:clamp(1rem,2.2vw,1.3rem);
  margin-bottom:1.25rem;
}
.home-hero .hero-btn{
  background:linear-gradient(135deg,var(--fayen-blue),var(--fayen-blue-2));
  color:#fff;
  border-radius:10px;
  padding:0.78rem 1.55rem;
  font-weight:600;
  box-shadow:0 10px 24px rgba(37,99,235,.35);
}
.home-hero .hero-btn:hover,
.home-hero .hero-btn:focus{
  color:#fff;
  text-decoration:none;
  transform:translateY(-1px);
  box-shadow:0 12px 26px rgba(37,99,235,.42);
}

/* Courses page: tracks + course cards */
.courses-hero-wrap{
  margin-top:64px;
  padding:0;
}
.courses-hero-wrap .row{
  margin:0;
}
.courses-banner{
  width:100%;
  height:300px;
  object-fit:cover;
  filter:brightness(.8);
}
.courses-page{
  padding-top:1.25rem;
  padding-bottom:2rem;
}
.courses-page h1.text-center{
  color:var(--fayen-ink);
  letter-spacing:.2px;
  margin-bottom:.45rem;
}
.courses-page .text-muted{
  color:var(--fayen-muted) !important;
}
.courses-page .course-card-link{
  display:block;
}
.courses-page .card{
  border:1px solid var(--fayen-line) !important;
  border-radius:14px !important;
  overflow:hidden;
  background:var(--fayen-surface);
  box-shadow:0 6px 20px rgba(15,23,42,.08) !important;
}
.courses-page .card:hover{
  transform:translateY(-4px);
  box-shadow:0 12px 28px rgba(15,23,42,.14) !important;
}
.courses-page .card-img-top{
  height:190px;
  object-fit:cover;
}
.courses-page .card-body{
  padding:1rem 1rem .9rem !important;
}
.courses-page .card-title{
  color:var(--fayen-ink);
  font-size:1.06rem;
  margin-bottom:.5rem;
}
.courses-page .card-text{
  color:#475569;
}
.courses-page .card-footer{
  background:#f8fbff !important;
  border-top:1px solid var(--fayen-line) !important;
}
.courses-page .btn-primary{
  background:var(--fayen-blue-2) !important;
  border-color:var(--fayen-blue-2) !important;
  border-radius:8px !important;
  font-weight:600;
}
.courses-page .btn-primary:hover,
.courses-page .btn-primary:focus{
  background:var(--fayen-blue) !important;
  border-color:var(--fayen-blue) !important;
}
.courses-page .btn-outline-dark{
  border-radius:8px !important;
  border-color:#334155 !important;
  color:#1e293b !important;
}
.courses-page .btn-outline-dark:hover,
.courses-page .btn-outline-dark:focus{
  background:#1e293b !important;
  border-color:#1e293b !important;
  color:#fff !important;
}

/* Footer polish */
.site-footer{
  background:linear-gradient(180deg,#0b1329,#0b1736);
}

@media (max-width:767.98px){
  .navbar .navbar-text{
    display:none;
  }
  .home-hero{
    margin-top:58px;
  }
  .home-hero .vid-parent,
  .home-hero video{
    min-height:74vh;
  }
  .courses-hero-wrap{
    margin-top:58px;
  }
  .courses-banner{
    height:210px;
  }
}

/* ===== SAFE UI POLISH: CONTACT FORM ===== */
#Contact.contact-section{
  margin-top:2.5rem !important;
  margin-bottom:2.5rem;
}
#Contact .contact-title{
  color:#0f172a;
  font-weight:700;
  letter-spacing:.2px;
  margin-bottom:1.2rem !important;
}
#Contact .contact-layout{
  align-items:stretch;
}
#Contact .contact-form-panel{
  background:#ffffff;
  border:1px solid #dbe6f4;
  border-radius:14px;
  box-shadow:0 10px 26px rgba(15,23,42,0.08);
  padding:1.25rem 1.1rem .4rem;
}
#Contact .form-control{
  border:1px solid #cbd5e1;
  border-radius:10px;
  padding:.75rem .85rem;
  color:#0f172a;
  background:#f8fbff;
  transition:border-color .2s ease, box-shadow .2s ease, background-color .2s ease;
}
#Contact .form-control::placeholder{
  color:#64748b;
}
#Contact .form-control:focus{
  border-color:#2563eb;
  background:#ffffff;
  box-shadow:0 0 0 3px rgba(37,99,235,.18);
}
#Contact textarea.form-control{
  min-height:150px;
  resize:vertical;
}
#Contact .btn.btn-primary{
  background:linear-gradient(135deg,#1d4ed8,#2563eb) !important;
  border:1px solid #1d4ed8 !important;
  border-radius:10px !important;
  font-weight:600;
  letter-spacing:.2px;
  padding:.62rem 1.35rem;
}
#Contact .btn.btn-primary:hover,
#Contact .btn.btn-primary:focus{
  background:linear-gradient(135deg,#1e40af,#1d4ed8) !important;
  border-color:#1e40af !important;
}
#Contact .contact-info-card{
  background:linear-gradient(155deg,#0b1736,#12306b) !important;
  border-radius:14px;
  box-shadow:0 12px 28px rgba(2,6,23,.25);
  transform:none;
  height:100%;
  margin-top:0;
  padding:1.5rem 1rem;
  display:flex;
  flex-direction:column;
  justify-content:center;
}
#Contact .contact-info-card h4{
  font-weight:700;
  margin-bottom:.7rem;
}
#Contact .contact-info-card p{
  margin-bottom:0;
  color:rgba(255,255,255,.9);
  line-height:1.7;
}

@media (max-width:767.98px){
  #Contact.contact-section{
    margin-top:1.7rem !important;
  }
  #Contact .contact-form-panel{
    padding:1rem .95rem .2rem;
    margin-bottom:1rem;
  }
}
