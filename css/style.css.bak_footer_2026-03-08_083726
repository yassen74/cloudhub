/* Hero polish */
.vid-content, .hero-content{
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  width: 100%;
  padding: 0 16px;
}
.hero-content h1{
  font-family: 'Ubuntu', sans-serif;
  font-weight: 700;
  letter-spacing: .5px;
  color: #fff;
  font-size: clamp(36px, 5vw, 64px);
  margin-bottom: 10px;
}
.hero-content h1 span{ color: #00d4ff; }
.hero-content p{
  color: rgba(255,255,255,.85);
  font-size: clamp(16px, 2vw, 22px);
  margin-bottom: 18px;
}
.hero-btn{
  display: inline-block;
  padding: 12px 28px;
  border-radius: 10px;
  font-weight: 600;
  text-decoration: none;
}

/* Footer (shared) */
.site-footer{
  background: #0f172a;
  color:#e5e7eb;
  border-top: 1px solid rgba(255,255,255,.10);
}
.site-footer .footer-brand{
  font-weight:700;
  font-size:15px;
  letter-spacing:.3px;
  margin-bottom:4px;
}
.site-footer .footer-tagline{
  color:#9ca3af;
  font-size:12px;
}

.site-footer .footer-head{
  font-weight:700;
  font-size:11px;
  letter-spacing:.7px;
  text-transform:uppercase;
  color:#cbd5e1;
  margin-bottom:8px;
}

.site-footer ul{
  list-style:none;
  padding:0;
  margin:0;
}

.site-footer .footer-links li{
  margin: 0 0 6px 0;
}
.site-footer .footer-links a{
  color:#cbd5e1;
  text-decoration:none;
  font-size:13px;
  transition: all .15s ease;
}
.site-footer .footer-links a:hover{
  color:#ffffff;
  transform: translateX(2px);
}

.site-footer .footer-contact li{
  display:flex;
  align-items:center;
  gap:8px;
  margin-bottom:7px;
  color:#cbd5e1;
  font-size:13px;
}
.site-footer .footer-contact i{
  width:16px;
  opacity:.9;
}
.site-footer .footer-contact a{
  color:#cbd5e1;
  text-decoration:none;
}
.site-footer .footer-contact a:hover{
  color:#ffffff;
  text-decoration:underline;
}

.site-footer .footer-divider{
  margin:12px 0 10px;
  border-top: 1px solid rgba(255,255,255,.10);
}

.site-footer .footer-social{
  display:flex;
  gap:8px;
}
.site-footer .footer-social a{
  width:30px;
  height:30px;
  border-radius:8px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border:1px solid rgba(255,255,255,.14);
  color:#e5e7eb;
  text-decoration:none;
  transition: all .15s ease;
}
.site-footer .footer-social a:hover{
  transform: translateY(-2px);
  border-color: rgba(255,255,255,.28);
  color:#ffffff;
}

.site-footer .footer-copy{
  color:#9ca3af;
  font-size:12px;
}

